# Optional Socrata application token for higher API limits.
# Create one at https://dev.socrata.com/
SOCRATA_APP_TOKEN=

# Optional override for the maximum number of rows downloaded per dataset.
SECOP_LIMIT=50000

# Default territory used by the dashboard before the user runs an analysis.
SECOP_DEPARTAMENTO=Distrito Capital de Bogotá
SECOP_MUNICIPIO=Bogotá
